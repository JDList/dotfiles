{
    "layer": "top",
    "position": "top",

    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["cpu","temperature","memory","battery"],

    "clock": {
        "format": "{:%H:%M:%S  %d-%m-%Y}",
        "interval": 1
    },
    "battery": {
        "bat": "BAT0",
        "format": "NC {capacity}% {icon}",
         "format-charging": "C {capacity}% {icon}",
         "format-full": "F {capacity}% {icon}"

    },
    "temperature": {
      "critical-threshold": 50,
      "format": " {temperatureC}°C"
    },
    "memory": {
        "format": "RAM {}%"
    },


    "cpu": {
        "format": "CPU {usage}%"
    }
}
